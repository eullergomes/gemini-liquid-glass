# Google AI Studio API key used only by the server-side chat route.
GOOGLE_GENERATIVE_AI_API_KEY=
# GOOGLE_GENERATIVE_AI_MODEL=gemini-2.5-flash-lite
GOOGLE_GENERATIVE_AI_MODEL=gemini-3.1-flash-lite

# Auth.js / NextAuth configuration.
AUTH_SECRET=
AUTH_URL=http://localhost:3000
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Supabase Postgres via Prisma.
# Transaction-mode pooler, used by the app at runtime.
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Session-mode/direct connection, used by Prisma migrations.
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@[REGION].pooler.supabase.com:5432/postgres"
